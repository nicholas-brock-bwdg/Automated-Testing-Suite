test.describe('{{view_id}}', () => {
  test('navigation — anchor links resolve without 404', async ({ page, request }) => {
    await page.goto('{{view_url}}', { timeout: 15000 });
    await expect(page.locator('.ia_perspectiveRoot')).toBeVisible({ timeout: 15000 });

    // Collect all fully-resolved hrefs from the rendered DOM
    const hrefs: string[] = await page.locator('a[href]').evaluateAll(
      (anchors: HTMLAnchorElement[]) =>
        anchors
          .map(a => a.href)
          .filter(
            h =>
              h &&
              !h.startsWith('javascript:') &&
              !h.startsWith('mailto:') &&
              !h.match(/^#/)
          )
    );

    for (const href of hrefs) {
      try {
        const response = await request.get(href, { timeout: 10000 });
        expect(
          response.status(),
          `Link on {{view_path}} returned 404: ${href}`
        ).not.toBe(404);
      } catch {
        // Network / timeout errors are not 404s — skip
      }
    }
  });
});
