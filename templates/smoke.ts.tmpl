import { test, expect } from '@playwright/test';

// Auto-generated by bootstrap.py — do not edit manually.
// View: {{view_path}}  ID: {{view_id}}

test.describe('{{view_id}}', () => {
  test('smoke — page loads without error', async ({ page }) => {
    const consoleErrors: string[] = [];
    page.on('console', msg => {
      if (msg.type() === 'error') consoleErrors.push(msg.text());
    });

    const response = await page.goto('{{view_url}}', { timeout: 15000 });
    expect(response?.ok(), `HTTP error for {{view_path}}: status ${response?.status()}`).toBe(true);

    await expect(page.locator('.ia_perspectiveRoot')).toBeVisible({ timeout: 15000 });

    // Filter noise: ignore favicon and SSL cert errors that don't affect the view
    const significant = consoleErrors.filter(
      e => !e.includes('favicon') && !e.includes('ERR_CERT_AUTHORITY_INVALID')
    );
    expect(
      significant,
      `Console errors on {{view_path}}: ${significant.join(' | ')}`
    ).toHaveLength(0);
  });
});
