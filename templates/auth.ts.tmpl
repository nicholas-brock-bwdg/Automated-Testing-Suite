import { test, expect } from '@playwright/test';
import { login } from '../helpers/login';

// Auto-generated by bootstrap.py — do not edit manually.
// View: {{view_path}}  ID: {{view_id}}
// This file is only generated for views where requires_auth is true.

test.describe('{{view_id}}', () => {
  test('auth — unauthenticated request reaches login', async ({ page }) => {
    await page.goto('{{view_url}}', { timeout: 15000 });

    const finalUrl = page.url();
    const loginViaUrl = !!finalUrl.match(/login|auth|status=401|status=403/i);
    const loginViaForm =
      (await page.locator('input[type="password"]').count()) > 0 ||
      (await page
        .locator('[class*="login" i], [id*="login" i], [class*="Login"]')
        .count()) > 0;

    expect(
      loginViaUrl || loginViaForm,
      `Expected login page but landed on: ${finalUrl}`
    ).toBe(true);
  });

  test('auth — authenticated request loads view', async ({ page }) => {
    await login(page, '{{view_url}}');
    await expect(page.locator('.ia_perspectiveRoot')).toBeVisible({ timeout: 15000 });

    const finalUrl = page.url();
    expect(
      finalUrl.match(/login|auth/i),
      `Still on login page after auth: ${finalUrl}`
    ).toBeNull();
  });

  test('auth — post-logout access is blocked', async ({ page, context }) => {
    await login(page, '{{view_url}}');
    await expect(page.locator('.ia_perspectiveRoot')).toBeVisible({ timeout: 15000 });

    // Clear session to simulate logout
    await context.clearCookies();

    await page.goto('{{view_url}}', { timeout: 15000 });

    const finalUrl = page.url();
    const loginViaUrl = !!finalUrl.match(/login|auth|status=401|status=403/i);
    const loginViaForm = (await page.locator('input[type="password"]').count()) > 0;

    expect(
      loginViaUrl || loginViaForm,
      `Expected to be blocked after logout but landed on: ${finalUrl}`
    ).toBe(true);
  });
});
